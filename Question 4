   "source": [
    "import requests\n",
    "from bs4 import BeautifulSoup\n",
    "import pandas as pd\n",
    "\n",
    "# 1. Download the data\n",
    "url = \"https://cf-courses-data.s3.us.cloud-object-storage.appdomain.cloud/IBMDeveloperSkillsNetwork-PY0220EN-SkillsNetwork/labs/project/stock.html\"\n",
    "html_data_2 = requests.get(url).text\n",
    "\n",
    "# 2. Define 'soup' (This fixes the NameError)\n",
    "soup = BeautifulSoup(html_data_2, 'html.parser')\n",
    "\n",
    "# 3. Extract and clean the data\n",
    "gme_revenue_list = []\n",
    "tables = soup.find_all(\"table\")\n",
    "\n",
    "# We use index 1 because the GameStop Quarterly Revenue table is usually the second table\n",
    "for row in tables[1].find_all(\"tr\"):\n",
    "    col = row.find_all(\"td\")\n",
    "    if col:\n",
    "        date = col[0].text\n",
    "        # Clean currency formatting\n",
    "        revenue = col[1].text.replace(\"$\", \"\").replace(\",\", \"\")\n",
    "        gme_revenue_list.append({\"Date\": date, \"Revenue\": revenue})\n",
    "\n",
    "gme_revenue = pd.DataFrame(gme_revenue_list)\n",
    "\n",
    "# Remove empty strings to prevent errors during plotting/analysis\n",
    "gme_revenue = gme_revenue[gme_revenue['Revenue'] != \"\"]\n",
    "\n",
    "print(gme_revenue.tail())"
   ]
